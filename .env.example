# ==============================================================
# mo-stock-selection 环境变量示例
# 使用方式： cp .env.example .env  然后填入真实值
# ==============================================================

# ---------- Tushare（必填）----------
# 注册后在 https://tushare.pro/user/token 获取 token
TUSHARE_TOKEN=your_tushare_token_here
# 可选：自定义 Tushare HTTP 地址（走内网/镜像时使用，留空则用官方默认）
# TUSHARE_HTTP_URL=http://121.40.135.59:8010/

# ---------- Claude / Anthropic（Phase 3 起必填）----------
ANTHROPIC_API_KEY=sk-ant-your_key_here
# 可选：自定义 Anthropic API base_url（走代理/镜像时使用，留空则用官方默认）
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# 默认模型，成本敏感用 sonnet，周末深度复盘可切 opus
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------- 数据库（必填）----------
# 本地 docker compose 起来后的默认连接串
DB_URL=postgresql+psycopg2://mo_stock:mo_stock@localhost:5432/mo_stock

# ---------- GTHT 灵犀（必填）----------
# 来源：灵犀/君弘 APP → API KEY 管理 → 复制生效中的 key
# Python 端会自动把此 key 写入 gtht_entry_json_path 指向的 JSON 文件
GTHT_API_KEY=your_gtht_api_key_here

# ---------- GTHT 辅助 LLM（OpenAI 兼容，开放式查询用）----------
# 用于 ingest/filter 层走自然语言调用 GTHT skill 时的 LLM 决策器
# 推荐选项（任选其一）：
#   DeepSeek:  base=https://api.deepseek.com/v1                        model=deepseek-chat
#   通义 Qwen:  base=https://dashscope.aliyuncs.com/compatible-mode/v1   model=qwen-plus
#   Kimi:      base=https://api.moonshot.cn/v1                         model=moonshot-v1-8k
GTHT_LLM_API_KEY=
GTHT_LLM_BASE_URL=
GTHT_LLM_MODEL=

# ---------- mo-skills 依赖定位 ----------
# 父目录 mo-skills 的绝对路径（GTHT node skill 通过 subprocess 调用）
MO_SKILLS_ROOT=D:/QuantProjects/mo-skills
# 国泰海通灵犀 API Key 文件位置（首次授权后由 GTHT skill 自动生成）
GTHT_ENTRY_JSON_PATH=./gtht-skill-shared/gtht-entry.json

# ---------- 运行时配置 ----------
LOG_LEVEL=INFO
# 报告输出目录
REPORT_DIR=./data/reports
# 原始数据缓存目录（便于 replay）
CACHE_DIR=./data/cache
